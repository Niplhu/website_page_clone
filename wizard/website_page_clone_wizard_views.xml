<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_website_page_clone_wizard_form" model="ir.ui.view">
        <field name="name">website.page.clone.wizard.form</field>
        <field name="model">website.page.clone.wizard</field>
        <field name="arch" type="xml">
            <form string="Clonar sitio web / pagina">
                <group>
                    <group>
                        <field name="source_mode"/>
                        <field name="source_website_id" required="source_mode == 'complete'"/>
                        <field name="source_page_id" domain="[('website_id', '=', source_website_id)]" required="source_mode == 'custom' or source_mode == 'complete'"/>
                        <field name="target_mode"/>
                        <field name="target_website_id" invisible="target_mode != 'existing'" required="target_mode == 'existing'" domain="[('id', '!=', source_website_id)]"/>
                        <field name="new_website_name" invisible="target_mode != 'new'" required="target_mode == 'new'"/>
                        <field name="new_website_domain" invisible="target_mode != 'new'"/>
                        <field name="new_website_company_id" invisible="target_mode != 'new'"/>
                    </group>
                    <group>
                        <field name="new_name" invisible="source_mode != 'custom'" required="source_mode == 'custom'"/>
                        <field name="new_url" invisible="source_mode != 'custom'" required="source_mode == 'custom'"/>
                        <field name="publish" invisible="source_mode != 'custom'"/>
                    </group>
                </group>
                <group>
                    <field name="copy_menu"/>
                    <field name="copy_seo"/>
                    <field name="copy_translations"/>
                    <field name="copy_shop"/>
                    <field name="copy_shop_settings" invisible="not copy_shop"/>
                    <field name="copy_shop_pricelists" invisible="not copy_shop"/>
                    <field name="copy_shop_categories" invisible="not copy_shop"/>
                    <field name="copy_shop_products" invisible="not copy_shop"/>
                </group>
                <footer>
                    <button name="action_clone_page" type="object" class="btn-primary" string="Clonar"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_website_page_clone_wizard" model="ir.actions.act_window">
        <field name="name">Clonar pagina</field>
        <field name="res_model">website.page.clone.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="website.model_website_page"/>
        <field name="binding_view_types">form,list</field>
        <field name="view_id" ref="view_website_page_clone_wizard_form"/>
    </record>
</odoo>
